<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<AssignMessage async="false" continueOnError="false" enabled="true" name="Assign-ValidBalance">
    <DisplayName>Assign-ValidBalance</DisplayName>
    <Set>
        <Payload contentType="application/json">
            {
              
                "accountNumber": "{apigee.accNum}",
                 "balance": "{account.balance}"

            }
        </Payload>
    </Set>
    <AssignVariable>
        <Name>name</Name>
        <Value/>
        <Ref/>
    </AssignVariable>
    <IgnoreUnresolvedVariables>true</IgnoreUnresolvedVariables>
    <AssignTo createNew="false" transport="http" type="request"/>
</AssignMessage>
<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OAuthV2 async="false" continueOnError="false" enabled="true" name="OAuth-GenerateToken">
    <DisplayName>OAuth-GenerateToken</DisplayName>
    <Operation>GenerateAccessToken</Operation>
    <SupportedGrantTypes>
        <GrantType>client_credentials</GrantType>
    </SupportedGrantTypes>
    <ClientId ref="request.formparam.client_id"/>
    <ClientSecret ref="request.formparam.client_secret"/>
    <GenerateResponse enabled="true"/>
    <ExpiresIn>3600000</ExpiresIn>
</OAuthV2>